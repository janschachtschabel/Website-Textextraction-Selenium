# FastAPI settings
# HOST: Bind address of the API (default: 0.0.0.0)
HOST=0.0.0.0
# PORT: TCP port of the API (default: 8000)
PORT=8000

# Logging (loguru)
# LOG_LEVEL: Minimum log level (DEBUG|INFO|WARNING|ERROR) – default: INFO
LOG_LEVEL=INFO
# LOG_JSON: bool (true|false) – JSON format for log aggregation (e.g. ELK/Loki)
LOG_JSON=false

# Authentication (optional)
# API_KEY: When set, all requests must send a valid Bearer token.
#   Header: Authorization: Bearer <API_KEY>
#   Leave empty = auth disabled (open access)
API_KEY=

# PII Anonymisation (Presidio + spaCy)
# PRESIDIO_DE_MODEL: spaCy model for German (must be downloaded once)
#   python -m spacy download de_core_news_lg
PRESIDIO_DE_MODEL=de_core_news_lg
# PRESIDIO_EN_MODEL: spaCy model for English
#   python -m spacy download en_core_web_lg
PRESIDIO_EN_MODEL=en_core_web_lg
# Note: Models are loaded in the background at server start (~30–60 s).
# Requests with anonymize=true return the original text while models are
# not yet ready (with a warning in the anonymization.warning field).

# Crawl defaults
# DEFAULT_MODE: auto|fast|js (default: auto)
DEFAULT_MODE=auto
# DEFAULT_JS_STRATEGY: speed|accuracy (default: speed)
DEFAULT_JS_STRATEGY=speed
# DEFAULT_TIMEOUT_SECONDS: int seconds (1–600), total budget per request
DEFAULT_TIMEOUT_SECONDS=240
# DEFAULT_RETRIES: int (0–10), retry attempts on network/5xx errors
DEFAULT_RETRIES=2
# DEFAULT_HEADLESS: bool (true|false), headless browser in JS mode
DEFAULT_HEADLESS=true
# DEFAULT_STEALTH: bool (true|false), enable anti-detection flags
DEFAULT_STEALTH=true
# DEFAULT_JS_AUTO_WAIT: bool (true|false), internal auto-waits (conservative)
DEFAULT_JS_AUTO_WAIT=true
# DEFAULT_MAX_BYTES: int bytes (1024–104857600), hard upper limit for response size
DEFAULT_MAX_BYTES=10485760
# DEFAULT_USER_AGENT: browser user-agent string for Selenium
DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36

# =============================================================================
# DEPLOYMENT PROFILE  (set the active profile in the values below)
# =============================================================================
#
# ── PERFORMANCE SETTING (default, recommended from 8 GB RAM / 2+ CPU cores) ──
#   Maximum throughput: 2 workers × 4 Chrome = 8 parallel JS renders.
#   Load-test sweet-spot: conc=4 at ~3 s mean latency, 0 errors.
#
#   UVICORN_WORKERS=2
#   SELENIUM_POOL_SIZE=2          # 4 Chrome at startup (2 per worker)
#   SELENIUM_MAX_POOL_SIZE=4      # max. 8 Chrome (4 per worker)
#   RESULT_CACHE_TTL=1800         # 30 min – for mostly static content
#   RESULT_CACHE_MAX_SIZE=500     # 500 MB cache
#
# ── SAFE SETTING (for development / low-resource environments / first run) ───
#   Stable single worker, small Chrome pool – low RAM footprint.
#   Chrome instances at startup: 1×1×2 = 2, maximum: 1×4×2 = 8.
#
#   UVICORN_WORKERS=1
#   SELENIUM_POOL_SIZE=1          # 2 Chrome at startup (1 per worker)
#   SELENIUM_MAX_POOL_SIZE=4      # max. 8 Chrome (4 per worker)
#   RESULT_CACHE_TTL=300          # 5 min
#   RESULT_CACHE_MAX_SIZE=200     # 200 MB cache
#
# =============================================================================

# Selenium Pool Configuration
# SELENIUM_POOL_SIZE: Initial driver pool size (int >=1)
SELENIUM_POOL_SIZE=2
# SELENIUM_MAX_POOL_SIZE: Upper limit for auto-scaling (int >= POOL_SIZE)
SELENIUM_MAX_POOL_SIZE=4
# SELENIUM_SCALE_THRESHOLD: Utilisation threshold for scale-up (float 0.0–1.0)
SELENIUM_SCALE_THRESHOLD=0.8

# Request Capacity & Queuing
# Note: Effective total capacity = UVICORN_WORKERS × SELENIUM_MAX_POOL_SIZE × 2
#   (factor 2 = two internal pools: normal + eager)
#   Example: 2 workers × 4 max-pool × 2 = 16 possible parallel JS requests
# MAX_QUEUE_SIZE: maximum queue length for waiting requests (int >=0)
MAX_QUEUE_SIZE=50
# QUEUE_TIMEOUT_SECONDS: maximum wait time in the queue (seconds)
QUEUE_TIMEOUT_SECONDS=60

# Media Handling (skip|metadata|full|none)
# MEDIA_CONVERSION_POLICY:
#   skip     → Do not convert audio/video (fast, recommended)
#   metadata → ffprobe metadata as JSON only (requires ffprobe)
#   full     → Full conversion via markitdown/ffmpeg (slow, high resource usage)
#   none     → No output at all for media (empty string)
MEDIA_CONVERSION_POLICY=skip

# HTML Conversion
# HTML_CONVERTER: trafilatura|markitdown|bs4 (default: trafilatura)
#   trafilatura → Fast, robust main-content extraction (fallback: MarkItDown → BS4)
#   markitdown  → Full HTML→Markdown conversion (fallback: BS4)
#   bs4         → Simple text extraction with BeautifulSoup (HTML only)
HTML_CONVERTER=trafilatura

# TRAFILATURA_CLEAN_MARKDOWN: bool (true|false)
#   true  → Clean Markdown (main content) via Trafilatura.extract(output_format=markdown)
#   false → Raw extraction via Trafilatura.html2txt (plain text, Markdown-compatible)
TRAFILATURA_CLEAN_MARKDOWN=true

# Security
# ALLOW_INSECURE_SSL: bool (true|false)
#   true  → SSL certificates are NOT validated (httpx verify=false)
#   false → Strict certificate validation (recommended)
ALLOW_INSECURE_SSL=false
# SSRF_PROTECTION: bool (true|false)
#   true  → Block requests to private/loopback IPs (127.x, 10.x, 192.168.x etc.)
#   false → All addresses allowed (only for closed internal environments)
SSRF_PROTECTION=true

# Result Cache (diskcache — SQLite-backed, WAL-optimised, shared across all workers)
# RESULT_CACHE_TTL: seconds a result is cached (0 = cache disabled)
#   Recommendation: 1800 (Performance) · 300 (Safe / dynamic content) · 0 (pipeline use)
RESULT_CACHE_TTL=1800
# RESULT_CACHE_MAX_SIZE: maximum cache size in MB
#   Recommendation: 500 (Performance) · 200 (Safe)
RESULT_CACHE_MAX_SIZE=500
# RESULT_CACHE_DIR: cache directory (empty = system temp directory)
#   All worker processes share the same directory automatically.
#   Windows: C:\Users\<user>\AppData\Local\Temp\volltextextraktion_cache
#   Linux:   /tmp/volltextextraktion_cache
RESULT_CACHE_DIR=

# Uvicorn Worker Processes (multiprocessing)
# UVICORN_WORKERS: number of parallel worker processes
#   1  = Safe Setting  (development / low-resource environments, minimal RAM)
#   2  = Performance Setting (recommended; 2 × SELENIUM_MAX_POOL_SIZE parallel JS requests)
#   4  = High load (4 CPU cores + ≥16 GB RAM recommended)
#   Note: Result cache and metrics are shared across workers via diskcache (SQLite, WAL mode)
#   — no Redis required. Rate limiters and Presidio models are isolated per worker.
#   Each worker starts SELENIUM_POOL_SIZE Chrome instances (+ auto-scaling up to MAX).
UVICORN_WORKERS=2

# Rate Limiting (0 = disabled)
# GLOBAL_RATE_LIMIT_RPS: maximum total requests per second across all domains (float, 0=off)
#   Protects the server from overload. Example: 5.0 = max. 5 crawls/s total.
GLOBAL_RATE_LIMIT_RPS=0
# DEFAULT_DOMAIN_RATE_LIMIT_RPS: max. requests per second per target domain (float, 0=off)
#   Prevents target sites from blocking the crawler. Example: 1.0 = 1 crawl/s per domain.
#   Can be overridden per request via crawl_rate_limit_rps.
DEFAULT_DOMAIN_RATE_LIMIT_RPS=0
